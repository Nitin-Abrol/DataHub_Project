{
  "datasets": [
    {
      "name": "70858539",
      "displayName": "Earthquake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_tbl"
      ],
      "catalog": "datahub",
      "schema": "default"
    },
    {
      "name": "e2e03630",
      "displayName": "Magnitude_Categorization",
      "queryLines": [
        "\r\n",
        "select count(*) as total_magnitude_bucket, magnitude_category from\r\n",
        "(select case \r\n",
        "  when cast(mag as decimal) < 2 then 'MICRO (<2)'\r\n",
        "  when cast(mag as decimal) between 2 and 3 then 'Minor (2-3)'\r\n",
        "  when cast(mag as decimal) between 3 and 4 then 'Light (3-4)'\r\n",
        "  else 'Moderate (4+)'\r\n",
        "end as magnitude_category\r\n",
        "from silver.earthquake_data_tbl\r\n",
        ") group by magnitude_category"
      ],
      "catalog": "datahub",
      "schema": "default"
    },
    {
      "name": "5d08c757",
      "displayName": "Country Wise Earthquake Count",
      "queryLines": [
        "select count(*) as event_count,\r\n",
        "  CASE \r\n",
        "    when size(split(place, \", \")) = 1 then split(place, \", \")[0]\r\n",
        "    else split(place, \", \")[1]\r\n",
        "  end as country \r\n",
        "from \r\n",
        "  (select time, title, mag, longitude, place, latitute from datahub.silver.earthquake_data_tbl)\r\n",
        "group by country"
      ],
      "catalog": "datahub",
      "schema": "default"
    }
  ],
